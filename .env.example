# 复制为 .env.development 或 .env.local 后填写
# 仅 VITE_ 前缀变量会暴露给前端（import.meta.env.VITE_xxx）

# 后端根地址：
# - 生产 / 直连：写完整 URL，如 https://api.example.com
# - 开发 + 自签证书：配合 vite 代理，写「以 / 开头」的前缀，如 /api-proxy（同目录下 VITE_PROXY_TARGET）
VITE_PROXY_TARGET=https://frp-dad.com:25937
VITE_API_BASE_URL=/api-proxy

# 仅开发：上游真实地址；与「以 / 开头的 VITE_API_BASE_URL」同时存在时启用 Vite 代理（secure: false 解决自签证书）
# VITE_PROXY_TARGET=https://frp-dad.com:25937

# 管理员注册页（无主导航入口）：浏览器访问 /register/admin，请求体含 role=admin
# 普通用户在 /login 注册不传 role

# 管理员注册请求体：角色字段名与取值（须与后端 DTO 一致）。管理员页会同时发送 role、userRole、user_role（同值）
# VITE_AUTH_REGISTER_ROLE_FIELD=role
# VITE_AUTH_REGISTER_ADMIN_ROLE=admin
# 若后端枚举为大写：VITE_AUTH_REGISTER_ADMIN_ROLE=ADMIN
# 若后端只认 userRole 或枚举大写，例如：VITE_AUTH_REGISTER_ROLE_FIELD=userRole 且 VITE_AUTH_REGISTER_ADMIN_ROLE=ADMIN

# 可选：与 Apifox 路径不一致时覆盖（默认 /auth/login、/auth/register）
# VITE_AUTH_LOGIN_PATH=/auth/login
# VITE_AUTH_REGISTER_PATH=/auth/register
# 详情接口 POST /{entity}{path}，默认 path=/filter（即 /campus/filter）；若为大写 /Filter：
# VITE_ENTITY_FILTER_PATH=/Filter
# 管理端 CRUD（与 Apifox）：POST /{entity}/upload、/update、/remove；路径可单独覆盖：
# VITE_ENTITY_UPLOAD_PATH=/upload
# VITE_ENTITY_UPDATE_PATH=/update
# VITE_ENTITY_REMOVE_PATH=/remove
# 自然语言查询：POST /search { query, user_id }
# VITE_NL_SEARCH_PATH=/search
# 查询记录 CRUD（仅自然语言查询页使用）：
# VITE_QUERY_RECORD_SEARCH_PATH=/query_record/search
# VITE_QUERY_RECORD_UPLOAD_PATH=/query_record/upload
# VITE_QUERY_RECORD_FILTER_PATH=/query_record/filter
# VITE_QUERY_RECORD_UPDATE_PATH=/query_record/update
# VITE_QUERY_RECORD_REMOVE_PATH=/query_record/remove

# 后端已写查询记录时保持 false；需要由前端再写入一条查询记录时设为 true
# VITE_CLIENT_QUERY_LOG=false
